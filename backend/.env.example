# CryptoPay Backend — Environment Variables

# ═══════════════════════════════════════════════
# FEATURE FLAG — set to "true" to use TRON path
# ═══════════════════════════════════════════════
USE_TRON=true

# ═══════════════════════════════════════════════
# TRON (Nile Testnet) — active when USE_TRON=true
# ═══════════════════════════════════════════════
# Vendor/merchant wallet — receives USDT via SunSwap V2
MERCHANT_TRON_ADDRESS=TYourMerchantTronAddress

# Swap wallet private key (hex, no 0x prefix)
# This wallet holds TRX and calls SunSwap V2 to swap TRX→USDT for the vendor.
# Fund with TRX from the Nile testnet faucet.
SWAP_WALLET_KEY=

# TRX → USD exchange rate (1 TRX = $X USD)
TRX_USD_RATE=0.25

# TronGrid Nile API
TRON_NILE_API=https://nile.trongrid.io
# SunSwap V2 router on Nile
SUNSWAP_ROUTER=TKzxdSv2FZKQrEqkKVgp5DcwEXBEKMg2Ax
# USDT TRC-20 on Nile
USDT_TRC20_ADDRESS=TXLAQ63Xg1NAzckPwKHvzw7CSEmLMEqcdj
# Wrapped TRX on Nile
WTRX_ADDRESS=TYsbWxNnyTgsZaTFaue9hby3KnDuwFBhwS

# ═══════════════════════════════════════════════
# BASE SEPOLIA (old flow) — active when USE_TRON=false
# ═══════════════════════════════════════════════
MERCHANT_WALLET_ADDRESS=0xYourMerchantWalletAddress
BASE_SEPOLIA_RPC_URL=

# Server port (default: 3001)
PORT=3001
