# CryptoPay Backend — Environment Variables

# The merchant's wallet address on Base Sepolia.
# RLUSD (USDC) is sent directly here — no treasury middleman.
MERCHANT_WALLET_ADDRESS=0xYourMerchantWalletAddress

# (Optional) Custom RPC endpoint for Base Sepolia.
# Defaults to Viem's public transport if not set.
BASE_SEPOLIA_RPC_URL=

# Server port (default: 3001)
PORT=3001
